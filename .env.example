# FireRL — OPNsense Configuration
# Copy this file to .env and fill in your values
# The web server reads these first; falls back to FireSenseCli/opnsense_config.py

# OPNsense firewall address (use https)
OPNSENSE_HOST=https://192.168.1.1

# API credentials (OPNsense → System → Access → Users → API Keys)
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here

# Set to true only if you have a valid TLS certificate on OPNsense
OPNSENSE_VERIFY_SSL=false

# Alias name — must match exactly what's in OPNsense (Firewall → Aliases)
BLOCKLIST_ALIAS=rl_blocklist

# UUIDs of the pre-created tighten rules (Firewall → Rules [new])
# Leave blank if you haven't created them yet
TIGHTEN_INBOUND_UUID=
TIGHTEN_OUTBOUND_UUID=

# Web server port (default: 8080)
PORT=8080
